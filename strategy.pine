//@version=6
// Gap and Go only — Micro Pullback removed after backtest showed 3 consecutive losses
strategy("PulseWebhook - Gap and Go", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

// ── Inputs ────────────────────────────────────────────────────────────────────
volAvgLen    = input.int(20,    "Volume Average Length")
gapThreshold = input.float(10.0,"Min Day Gain % (Gap threshold)")  // FIX 3: must be up ≥10% on the day

// ── Indicators ────────────────────────────────────────────────────────────────
vwap   = ta.vwap(hlc3)
avgVol = ta.sma(volume, volAvgLen)

// ── Time Window: 14:00–15:30 UK only (= 09:00–10:30 EST) ─────────────────────
// FIX 2: captures pre-market ramp and opening bell surge; no signals outside this window
hourUK   = hour(time, "Europe/London")
minUK    = minute(time, "Europe/London")
timeUK   = hourUK * 100 + minUK
inWindow = timeUK >= 1400 and timeUK < 1530

// ── Day Performance ───────────────────────────────────────────────────────────
prevClose = request.security(syminfo.tickerid, "D", close[1])
changePct = (close - prevClose) / prevClose * 100
relVol    = volume / avgVol

// ── Pre-market High (rolling 30-bar lookback on 1m = ~30 min) ─────────────────
// FIX 4: stop is placed at this level — price closing back below it means trade has failed
preMarketHigh = ta.highest(high, 30)

// ── Gap and Go Entry Conditions (FIX 3) ───────────────────────────────────────
upTenPct     = changePct >= gapThreshold           // stock up ≥10% on the day
aboveVWAP    = close > vwap                        // price above VWAP
breaksPMHigh = close > preMarketHigh[1]            // candle closes above pre-market high
volumeSurge  = volume >= volume[1] * 3             // breakout candle ≥3× previous candle volume
isMarketOpen = session.ismarket

gapAndGo = upTenPct and aboveVWAP and breaksPMHigh and volumeSurge and isMarketOpen and inWindow

// ── Stop & Target ─────────────────────────────────────────────────────────────
// FIX 4: stop = pre-market high (the breakout level; close back below = failed trade)
// FIX 6: target = 2.5× risk
gapStop   = preMarketHigh[1]
gapRisk   = close - gapStop                        // always > 0 when breaksPMHigh is true
gapTarget = close + 2.5 * gapRisk

// ── Position Sizing (FIX 5) ───────────────────────────────────────────────────
// Cheap stocks get lower % allocation to contain volatility risk
pctOfEquity = close < 1.0 ? 0.10 :
              close < 2.0 ? 0.20 : 0.40
qtyShares   = math.max(1, math.floor(strategy.equity * pctOfEquity / close))

// ── Strategy Entry ────────────────────────────────────────────────────────────
if gapAndGo and strategy.position_size == 0 and gapRisk > 0
    strategy.entry("GapGo", strategy.long, qty=qtyShares, comment="GG")
    strategy.exit("GapGo SL/TP", "GapGo", stop=gapStop, limit=gapTarget)

// ── Alerts ────────────────────────────────────────────────────────────────────
if gapAndGo
    alert(
     '{"action":"buy"' +
     ',"symbol":"'   + syminfo.ticker + '"' +
     ',"price":'     + str.tostring(close) +
     ',"stop":'      + str.tostring(gapStop) +
     ',"target":'    + str.tostring(gapTarget) +
     ',"reason":"Gap and Go - up ' + str.tostring(math.round(changePct, 1)) + '% on day, broke PM high on 3x volume, above VWAP, 14:00-15:30 UK"' +
     ',"change_pct":' + str.tostring(math.round(changePct, 2)) +
     ',"relative_volume":' + str.tostring(math.round(relVol, 2)) + '}',
     alert.freq_once_per_bar_close)

if strategy.position_size > 0 and close < strategy.position_avg_price * 0.97
    alert(
     '{"action":"close"' +
     ',"symbol":"' + syminfo.ticker + '"' +
     ',"price":'   + str.tostring(close) +
     ',"reason":"Stop hit - closed below PM high"}',
     alert.freq_once_per_bar_close)

// ── Chart ─────────────────────────────────────────────────────────────────────
plot(vwap,          "VWAP",    color=color.blue, linewidth=2)
plot(preMarketHigh, "PM High", color=color.gray, linewidth=1, style=plot.style_stepline)

var line stopLine = na
var line targLine = na

if gapAndGo and gapRisk > 0
    stopLine := line.new(bar_index, gapStop,   bar_index + 20, gapStop,   color=color.red,  width=2)
    targLine := line.new(bar_index, gapTarget, bar_index + 20, gapTarget, color=color.blue, width=2)
    label.new(bar_index, low,
     "GG +" + str.tostring(math.round(changePct, 1)) + "%  3×vol",
     style=label.style_label_up, color=color.purple, textcolor=color.white, size=size.small)

plotshape(gapAndGo, style=shape.triangleup, location=location.belowbar,
          color=color.purple, size=size.normal, title="Gap and Go")

// ── Hidden series for downstream consumers ────────────────────────────────────
plot(gapAndGo ? gapStop   : na, "Stop",       display=display.none)
plot(gapAndGo ? gapTarget : na, "Target",     display=display.none)
plot(changePct,                  "Change_Pct", display=display.none)
plot(relVol,                     "Rel_Vol",    display=display.none)
