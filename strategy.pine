//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// PulseWebhook — MoneyMarch Momentum System
// Based on MoneyMarch Care Package 2.0 + proven momentum trading rules
// ─────────────────────────────────────────────────────────────────────────────
// CRITERIA (all 5 checked on dashboard):
//   1. Price $1–$20
//   2. Up 15%+ on day (gap/move)
//   3. Catalyst (manual — check news)
//   4. Relative Volume 2x+ (5x ideal)
//   5. Float <10M (manual — check scanner)
//
// ENTRY SIGNALS (3 types, all require MACD open + above VWAP):
//   A. VWAP Break & Retest — price breaks above VWAP, pulls back to touch
//      it, then surges above previous candle high. Most reliable signal.
//   B. 9 EMA Pullback — in uptrend (9>20), price pulls back to 9 EMA
//      then bounces with volume. Clean momentum continuation.
//   C. Breakout — price breaks above highest high of last 10 bars with
//      volume surge. Catches flat top breakouts and new highs.
//
// EXITS:
//   Hard stop: Below entry candle low (or pattern low)
//   Profit target: 2:1 risk/reward (risk 10c → target 20c)
//   VWAP stop: Close below VWAP = momentum dead
//   MACD stop: MACD crosses below signal = trend reversing
//   Time stop: 60 bars (1 hour on 1min chart) — move on
//
// RISK MANAGEMENT:
//   Daily goal: 10% of account. Max loss: 5%. Stop trading at either.
//   Position: 10% of equity per trade (conservative for $500 account)
//
// HOW TO USE:
//   1. Run TradingView scanner: Price $1-20, Change% >15%, RelVol >2
//   2. Check news/catalyst manually
//   3. Apply this strategy to the chart (1min timeframe)
//   4. Dashboard shows all criteria — GREEN = met, RED = not met
//   5. Wait for entry signal (green triangle). Don't chase.
//   6. Let the 2:1 target or stop do its job. Don't move stop down.
// ─────────────────────────────────────────────────────────────────────────────
strategy("PulseWebhook — MoneyMarch", overlay=true,
     initial_capital    = 500,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.0,
     slippage           = 3,
     calc_on_every_tick = true)

// ── INPUTS ───────────────────────────────────────────────────────────────────
backtest_mode = input.bool(true, "Backtest Mode",
     tooltip="ON: lower thresholds for historical data. OFF: strict live criteria.")

start_date = input.time(timestamp("2024-01-01 00:00"), "Backtest Start Date",
     group="Backtest Range")
end_date   = input.time(timestamp("2099-12-31 00:00"), "Backtest End Date",
     group="Backtest Range")
in_date_range = time >= start_date and time <= end_date

// Criteria thresholds
min_price    = input.float(1.0,  "Min Price",          minval=0.1, group="Criteria")
max_price    = input.float(20.0, "Max Price",          minval=1.0, group="Criteria")
min_change   = input.float(15.0, "Min % Change on Day", minval=1.0, group="Criteria")
min_rvol     = input.float(2.0,  "Min Relative Volume", minval=0.5, step=0.5, group="Criteria")

// Entry tuning
rr_ratio     = input.float(2.0,  "Risk:Reward Ratio",  minval=1.0, step=0.5, group="Entry",
     tooltip="2.0 = target is 2x your risk. MoneyMarch recommends 2:1.")
atr_buffer   = input.float(0.5,  "Stop ATR Buffer",    minval=0.1, step=0.1, group="Entry",
     tooltip="Extra buffer below candle low for stop loss.")
time_stop_bars = input.int(60,   "Time Stop (bars)",    minval=10, maxval=300, group="Entry")

// Session windows (EST)
entry_start_h = input.int(9,  "Entry Start Hour EST", minval=0, maxval=23, group="Time Window")
entry_start_m = input.int(30, "Entry Start Min",      minval=0, maxval=59, group="Time Window")
entry_end_h   = input.int(11, "Entry End Hour EST",   minval=0, maxval=23, group="Time Window")
entry_end_m   = input.int(30, "Entry End Min",        minval=0, maxval=59, group="Time Window",
     tooltip="MoneyMarch's best hours: pre-market + first 2 hours. Default 9:30-11:30.")

// Daily risk guardrails
daily_goal_pct  = input.float(10.0, "Daily Goal %",  minval=1.0, group="Risk Guardrails")
daily_max_loss  = input.float(5.0,  "Max Daily Loss %", minval=1.0, group="Risk Guardrails")

// Signal toggles
use_vwap_reclaim = input.bool(true, "Enable VWAP Reclaim Signal", group="Signals")
use_ema_pullback = input.bool(true, "Enable 9 EMA Pullback Signal", group="Signals")
use_breakout     = input.bool(true, "Enable Breakout Signal", group="Signals")

// ── TIME ─────────────────────────────────────────────────────────────────────
hour_est   = hour(time, "America/New_York")
minute_est = minute(time, "America/New_York")
time_est   = hour_est * 100 + minute_est
new_day    = not na(dayofweek[1]) and dayofweek != dayofweek[1]

entry_start = entry_start_h * 100 + entry_start_m
entry_end   = entry_end_h * 100 + entry_end_m
in_window   = time_est >= entry_start and time_est < entry_end

// ── CORE INDICATORS ─────────────────────────────────────────────────────────
atr14  = ta.atr(14)
vwap_v = ta.vwap(hlc3)
ema9   = ta.ema(close, 9)
ema20  = ta.ema(close, 20)
ema200 = ta.ema(close, 200)
rsi14  = ta.rsi(close, 14)

// MACD
[macd_line, signal_line, _hist] = ta.macd(close, 12, 26, 9)
macd_open = macd_line > signal_line

// Volume
avg_vol  = ta.sma(volume, 20)
rel_vol  = avg_vol > 0 ? volume / avg_vol : 0.0

// Plot indicators
plot(vwap_v, "VWAP",    color=color.blue,   linewidth=2)
plot(ema9,   "9 EMA",   color=color.orange,  linewidth=1)
plot(ema20,  "20 EMA",  color=color.yellow,  linewidth=1)
plot(ema200, "200 EMA", color=color.gray,    linewidth=1, style=plot.style_circles)

// ── GAP / CHANGE % CALCULATION ──────────────────────────────────────────────
var float day_open    = na
var float prev_close  = na
var float change_pct  = 0.0

if new_day
    prev_close := close[1]
    day_open   := na
    change_pct := 0.0

if na(day_open) and not na(open)
    day_open := open

// Track running change % throughout the day (high of day vs prev close)
var float day_high = na
if new_day
    day_high := high
else
    day_high := math.max(nz(day_high, high), high)

change_pct := if not na(prev_close) and prev_close > 0
    (day_high - prev_close) / prev_close * 100
else if not na(day_open) and day_open > 0
    (day_high - day_open) / day_open * 100
else
    0.0

// ── CRITERIA CHECKS ─────────────────────────────────────────────────────────
price_ok    = close >= min_price and close <= max_price
change_ok   = backtest_mode ? change_pct >= 5.0 : change_pct >= min_change
rvol_ok     = backtest_mode ? rel_vol >= 1.5 : rel_vol >= min_rvol
above_vwap  = close > vwap_v
ema_aligned = ema9 > ema20  // 9 above 20 = uptrend

// Criteria score (out of 5 — catalyst and float are manual)
auto_score = (price_ok ? 1 : 0) + (change_ok ? 1 : 0) + (rvol_ok ? 1 : 0)

// ── PRE-MARKET HIGH ─────────────────────────────────────────────────────────
var float premarket_high = 0.0
in_premarket = time_est >= 400 and time_est < 930

if new_day
    premarket_high := 0.0
if in_premarket
    premarket_high := math.max(premarket_high, high)

prevday_high  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
effective_pmh = if premarket_high > 0
    premarket_high
else if not na(prevday_high) and prevday_high > 0
    prevday_high
else
    high[1]

// ── HALF & WHOLE DOLLAR LEVELS ──────────────────────────────────────────────
// MoneyMarch: half and whole dollars are natural support/resistance
whole_above = math.ceil(close)
whole_below = math.floor(close)
half_above  = whole_below + 0.5
half_level  = close < half_above ? half_above : whole_above

// Plot nearest half/whole dollar levels as reference
plot(whole_above, "Whole $ Above", color=color.new(color.white, 70),
     linewidth=1, style=plot.style_cross)
plot(whole_below > 0 ? whole_below : na, "Whole $ Below",
     color=color.new(color.white, 70), linewidth=1, style=plot.style_cross)

// ── DAILY P&L TRACKING ──────────────────────────────────────────────────────
var float day_start_equity = na
var bool  hit_goal         = false
var bool  hit_max_loss     = false

if new_day
    day_start_equity := strategy.equity
    hit_goal         := false
    hit_max_loss     := false

daily_pnl_pct = not na(day_start_equity) and day_start_equity > 0 ? (strategy.equity - day_start_equity) / day_start_equity * 100 : 0.0

if daily_pnl_pct >= daily_goal_pct
    hit_goal := true
if daily_pnl_pct <= -daily_max_loss
    hit_max_loss := true

guardrails_ok = not hit_goal and not hit_max_loss

// ── SIGNAL A: VWAP BREAK & RETEST ──────────────────────────────────────────
// MoneyMarch's #1 strategy: price breaks above VWAP, pulls back to test it,
// then surges. Entry on the surge candle after retest holds.

var bool vwap_broken_up = false
var bool vwap_retested  = false

if new_day
    vwap_broken_up := false
    vwap_retested  := false

// Detect VWAP break from below
if close > vwap_v and close[1] <= vwap_v
    vwap_broken_up := true
    vwap_retested  := false

// Detect retest (price dips back to within 0.5 ATR of VWAP after breaking above)
if vwap_broken_up and not vwap_retested
    if low <= vwap_v + atr14 * 0.3 and close > vwap_v
        vwap_retested := true

// Entry: after retest, bullish candle breaks above previous high
vwap_signal = use_vwap_reclaim and vwap_retested and close > high[1] and close > open and macd_open and volume > avg_vol * 1.5

// Reset after signal fires
if vwap_signal
    vwap_broken_up := false
    vwap_retested  := false

// ── SIGNAL B: 9 EMA PULLBACK ───────────────────────────────────────────────
// MoneyMarch: when 9 EMA > 20 EMA, price pulls back to touch 9 EMA then
// bounces. Stop = below 9 EMA or below candle low.

pulled_to_ema  = low <= ema9 * 1.002 and low >= ema9 * 0.995  // touched 9 EMA (within 0.5%)
bounce_candle  = close > open and close > ema9                  // bullish candle closing above
ema_pullback_signal = use_ema_pullback and ema_aligned and pulled_to_ema and bounce_candle and macd_open and above_vwap and volume > avg_vol

// ── SIGNAL C: MOMENTUM BREAKOUT ────────────────────────────────────────────
// Catches flat top breakouts and new highs with volume confirmation
highest_10     = ta.highest(high, 10)
breakout       = close > highest_10[1] and close > open
vol_surge      = volume > avg_vol * 2.0
breakout_signal = use_breakout and breakout and vol_surge and above_vwap and macd_open

// ── COMBINED ENTRY LOGIC ────────────────────────────────────────────────────
no_position = strategy.position_size == 0
base_ok     = in_date_range and in_window and price_ok and guardrails_ok and no_position

// At least auto criteria must pass (change + rvol are gated by backtest/live thresholds)
criteria_ok = change_ok and rvol_ok

entry_vwap     = base_ok and criteria_ok and vwap_signal
entry_ema      = base_ok and criteria_ok and ema_pullback_signal and not vwap_signal
entry_breakout = base_ok and criteria_ok and breakout_signal and not vwap_signal and not ema_pullback_signal

can_entry   = entry_vwap or entry_ema or entry_breakout
entry_type  = entry_vwap ? "VWAP" : entry_ema ? "EMA" : "BRK"

// ── ENTRY EXECUTION ─────────────────────────────────────────────────────────
var int   entry_bar   = 0
var float entry_price = na
var float entry_stop  = na
var float entry_target = na
var line  stop_line   = na
var line  target_line = na

if can_entry
    // Stop: below current candle low minus ATR buffer
    stop_px  = low - atr14 * atr_buffer
    risk     = close - stop_px
    target_px = close + risk * rr_ratio

    entry_price  := close
    entry_stop   := stop_px
    entry_target := target_px
    entry_bar    := bar_index

    strategy.entry("MM_" + entry_type, strategy.long, comment=entry_type)
    strategy.exit("TP/SL", "MM_" + entry_type, stop=stop_px, limit=target_px)

    // Draw stop line (red) and target line (green)
    if not na(stop_line)
        line.delete(stop_line)
    if not na(target_line)
        line.delete(target_line)
    stop_line   := line.new(bar_index, stop_px, bar_index + 60, stop_px,
                   color=color.red, width=2, style=line.style_dashed)
    target_line := line.new(bar_index, target_px, bar_index + 60, target_px,
                   color=color.lime, width=2, style=line.style_dashed)

// Entry markers
plotshape(entry_vwap,     style=shape.triangleup, location=location.belowbar,
         color=color.lime,   size=size.normal, title="VWAP Entry")
plotshape(entry_ema,      style=shape.triangleup, location=location.belowbar,
         color=color.orange, size=size.normal, title="EMA Entry")
plotshape(entry_breakout, style=shape.triangleup, location=location.belowbar,
         color=color.aqua,   size=size.normal, title="Breakout Entry")

// ── EXITS ───────────────────────────────────────────────────────────────────
// VWAP Stop: close below VWAP = momentum dead (MoneyMarch rule)
if strategy.position_size > 0 and close < vwap_v
    strategy.close_all("VWAP Lost")

// MACD Stop: trend reversing
if strategy.position_size > 0 and not macd_open and bar_index - entry_bar > 3
    strategy.close_all("MACD Cross")

// Time Stop: don't sit in dead trades
if strategy.position_size > 0 and bar_index - entry_bar > time_stop_bars
    strategy.close_all("Time Stop")

// Guardrail stop: hit daily goal or max loss — close and stop trading
if strategy.position_size > 0 and (hit_goal or hit_max_loss)
    close_reason = hit_goal ? "Daily Goal" : "Max Loss"
    strategy.close_all(close_reason)

// Reset on flat
if strategy.position_size == 0 and strategy.position_size[1] > 0
    entry_price  := na
    entry_stop   := na
    entry_target := na

// ── PMH LABEL ───────────────────────────────────────────────────────────────
var label pmh_lbl = na
pmh_tag = premarket_high > 0 ? "PMH" : "PDH"

plot(effective_pmh > 0 ? effective_pmh : na, "PM High",
     color=color.orange, linewidth=1, style=plot.style_circles)

if barstate.islast and effective_pmh > 0
    if not na(pmh_lbl)
        label.delete(pmh_lbl)
    pmh_lbl := label.new(bar_index + 2, effective_pmh,
                 pmh_tag + "  " + str.tostring(effective_pmh, "#.##"),
                 style=label.style_label_left, color=color.orange,
                 textcolor=color.black, size=size.small)

// ── ALERTS ──────────────────────────────────────────────────────────────────
if can_entry
    alert('{"action":"buy","type":"' + entry_type + '","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"stop":' + str.tostring(entry_stop) + ',"target":' + str.tostring(entry_target) + ',"gap_pct":' + str.tostring(math.round(change_pct, 2)) + ',"rel_vol":' + str.tostring(math.round(rel_vol, 2)) + ',"rsi":' + str.tostring(math.round(rsi14, 1)) + '}', alert.freq_once_per_bar_close)

if strategy.position_size[1] > 0 and strategy.position_size == 0
    alert('{"action":"close","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar_close)

// ── GUARDRAIL ALERTS ────────────────────────────────────────────────────────
if hit_goal and not hit_goal[1]
    alert('{"action":"guardrail","type":"daily_goal","pnl_pct":' + str.tostring(math.round(daily_pnl_pct, 2)) + '}', alert.freq_once_per_bar)

if hit_max_loss and not hit_max_loss[1]
    alert('{"action":"guardrail","type":"max_loss","pnl_pct":' + str.tostring(math.round(daily_pnl_pct, 2)) + '}', alert.freq_once_per_bar)

// ── INFO DASHBOARD ──────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 16,
     bgcolor=color.new(color.black, 75), border_color=color.gray, border_width=1)

if barstate.islast
    // Header
    table.cell(dash, 0, 0, "MoneyMarch", text_color=color.white, text_size=size.small,
         bgcolor=color.new(color.purple, 30))
    table.cell(dash, 1, 0, backtest_mode ? "BACKTEST" : "LIVE",
         text_color=backtest_mode ? color.yellow : color.lime, text_size=size.small,
         bgcolor=color.new(color.purple, 30))

    // Criteria section
    table.cell(dash, 0, 1, "--- CRITERIA ---", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(auto_score) + "/3 auto", text_color=auto_score >= 3 ? color.lime : color.orange, text_size=size.tiny)

    table.cell(dash, 0, 2, "Price", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, "$" + str.tostring(close, "#.##"),
         text_color=price_ok ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 3, "Change %", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, str.tostring(math.round(change_pct, 1)) + "%",
         text_color=change_ok ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 4, "Rel Volume", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, str.tostring(math.round(rel_vol, 1)) + "x",
         text_color=rvol_ok ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 5, "Catalyst", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, "CHECK NEWS", text_color=color.yellow, text_size=size.small)

    table.cell(dash, 0, 6, "Float", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, "CHECK SCANNER", text_color=color.yellow, text_size=size.small)

    // Signals section
    table.cell(dash, 0, 7, "--- SIGNALS ---", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 7, "", text_size=size.tiny)

    table.cell(dash, 0, 8, "VWAP", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 8, above_vwap ? "ABOVE" : "BELOW",
         text_color=above_vwap ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 9, "MACD", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 9, macd_open ? "OPEN" : "CLOSED",
         text_color=macd_open ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 10, "EMA Trend", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 10, ema_aligned ? "9 > 20" : "WEAK",
         text_color=ema_aligned ? color.lime : color.red, text_size=size.small)

    table.cell(dash, 0, 11, "RSI", text_color=color.white, text_size=size.small)
    rsi_status = rsi14 > 70 ? "OVERBOUGHT" : rsi14 < 30 ? "OVERSOLD" : str.tostring(math.round(rsi14, 0))
    table.cell(dash, 1, 11, rsi_status,
         text_color=rsi14 > 70 ? color.red : rsi14 < 30 ? color.red : color.lime, text_size=size.small)

    // Status section
    table.cell(dash, 0, 12, "--- STATUS ---", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 1, 12, "", text_size=size.tiny)

    table.cell(dash, 0, 13, "Window", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 13, in_window ? "OPEN" : "CLOSED",
         text_color=in_window ? color.lime : color.gray, text_size=size.small)

    table.cell(dash, 0, 14, "Daily P&L", text_color=color.white, text_size=size.small)
    pnl_col = daily_pnl_pct > 0 ? color.lime : daily_pnl_pct < 0 ? color.red : color.gray
    table.cell(dash, 1, 14, str.tostring(math.round(daily_pnl_pct, 2)) + "%",
         text_color=pnl_col, text_size=size.small)

    guardrail_text = hit_goal ? "GOAL HIT - STOP" : hit_max_loss ? "MAX LOSS - STOP" : "TRADING"
    guardrail_col  = hit_goal ? color.lime : hit_max_loss ? color.red : color.green
    table.cell(dash, 0, 15, "Guardrail", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 15, guardrail_text, text_color=guardrail_col, text_size=size.small)

// ── DEBUG (Data Window only) ────────────────────────────────────────────────
plot(change_pct,        "Change% Debug",  color=color.yellow, display=display.data_window)
plot(rel_vol,           "RelVol Debug",   color=color.blue,   display=display.data_window)
plot(effective_pmh,     "PMH Debug",      color=color.orange, display=display.data_window)
plot(macd_line,         "MACD Debug",     color=color.green,  display=display.data_window)
plot(signal_line,       "Signal Debug",   color=color.red,    display=display.data_window)
plot(nz(entry_stop),    "Stop Debug",     color=color.red,    display=display.data_window)
plot(nz(entry_target),  "Target Debug",   color=color.lime,   display=display.data_window)
plot(daily_pnl_pct,     "DailyPnL Debug", color=color.white,  display=display.data_window)

// ── Hidden series for webhook ───────────────────────────────────────────────
plot(entry_stop,   "stop_price",  display=display.none)
plot(entry_target, "target_price", display=display.none)
