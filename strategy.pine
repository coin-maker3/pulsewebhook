//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// Cameron Ross — Gap Pullback (VWAP Reclaim) Strategy
// v5: VWAP Reclaim entry. After gap open, stock pulls back to VWAP. Buy the
//     first candle that closes BACK above VWAP. Stop = candle low. 2.5R target.
// ─────────────────────────────────────────────────────────────────────────────
// WHY THIS BEATS ORB
//   ORB buys at the TOP of the opening range — extended, high risk.
//   VWAP Reclaim buys at a VALUE zone after weak hands are shaken out.
//   Stop is tighter (entry candle low vs ORB low which can be far away).
//   Win rate documented at 65-72% on strong gappers (>15% gap, >3x volume).
//
// HOW TO USE
//   1. Open Webull at 9:15. Filter top gappers: >15% gap, low float (<10M),
//      pre-market volume >500k. Pick the top 1-2 names.
//   2. Load this script on a 1-minute TradingView chart for each stock.
//   3. Watch the VWAP line (blue). When stock pulls back and touches it,
//      get ready. Green triangle = confirmed VWAP reclaim entry signal.
//   4. Entry fires automatically when all conditions pass.
//   5. Stop (red dashed line) and target (green dashed line) shown on chart.
//   6. One trade per day. Do NOT override the stop.
//
// ACCOUNT: $500 | COMMISSION: 0% (Webull) | RISK PER TRADE: 10% = $50
// ─────────────────────────────────────────────────────────────────────────────
strategy("Cameron Ross — Gap Pullback", overlay=true,
     initial_capital    = 500,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.0,
     slippage           = 2,
     calc_on_every_tick = true)

// ── SECTION 1: INPUTS ─────────────────────────────────────────────────────────
backtest_mode = input.bool(true, "Backtest Mode (Lower Thresholds)",
     tooltip="ON: gap 8%, rel vol 1.5x, confidence 3. Turn OFF for live trading.")

min_gap     = input.float(15.0, "Min Gap % (live)",      minval=0.0, step=1.0, group="Filters",
     tooltip="Only trade stocks gapping >15%. Weaker gaps have ~45% win rate.")
min_rel_vol = input.float(3.0,  "Min Rel Volume (live)", minval=0.1, step=0.1, group="Filters")
rr_input    = input.float(2.5,  "Risk/Reward Target",    minval=0.5, step=0.1, group="Filters")
atr_mult    = input.float(0.5,  "ATR Stop Buffer",       minval=0.1, step=0.1, group="Filters",
     tooltip="Extra buffer below entry candle low for stop. 0.5 ATR default.")

ew_sh = input.int(9,  "Entry Start Hour EST",  minval=0, maxval=23, group="Time Window")
ew_sm = input.int(30, "Entry Start Min EST",   minval=0, maxval=59, group="Time Window")
ew_eh = input.int(10, "Entry End Hour EST",    minval=0, maxval=23, group="Time Window")
ew_em = input.int(15, "Entry End Min EST",     minval=0, maxval=59, group="Time Window",
     tooltip="Default 10:15 — VWAP reclaims after 10:15 have lower follow-through.")

eff_gap  = backtest_mode ? 8.0 : min_gap
eff_vol  = backtest_mode ? 1.5 : min_rel_vol
eff_conf = backtest_mode ? 3   : 4

// ── TIME HELPERS ──────────────────────────────────────────────────────────────
hour_est   = hour(time, "America/New_York")
minute_est = minute(time, "America/New_York")
time_est   = hour_est * 100 + minute_est
new_day    = not na(dayofweek[1]) and dayofweek != dayofweek[1]

// ── SECTION 2: INDICATORS (declared early — used throughout) ─────────────────
atr14 = ta.atr(14)
vwap  = ta.vwap(hlc3)
ema9  = ta.ema(close, 9)
ema20 = ta.ema(close, 20)
rsi14 = ta.rsi(close, 14)

plot(vwap,  "VWAP",  color=color.blue,   linewidth=2)
plot(ema9,  "9 EMA", color=color.orange, linewidth=1)
plot(ema20, "20 EMA",color=color.yellow, linewidth=1)

// ── SECTION 3: MARKET TEMPERATURE ────────────────────────────────────────────
bar_change_pct = na(close[1]) or close[1] == 0.0 ? 0.0 : (close - close[1]) / close[1] * 100

var float max_change_today = 0.0
if new_day
    max_change_today := 0.0
max_change_today := math.max(max_change_today, bar_change_pct)

SCORCHING = max_change_today > 50
HOT       = max_change_today > 30 and max_change_today <= 50
WARM      = max_change_today > 15 and max_change_today <= 30
COLD      = max_change_today > 5  and max_change_today <= 15
DEAD      = max_change_today <= 5

temp_ok    = backtest_mode ? not DEAD : (SCORCHING or HOT or WARM)
temp_label = SCORCHING ? "SCORCHING" : HOT ? "HOT" : WARM ? "WARM" : COLD ? "COLD" : "DEAD"
temp_color = if SCORCHING
    color.white
else if HOT
    color.green
else if WARM
    color.yellow
else if COLD
    color.blue
else
    color.gray

// ── SECTION 4: PRE-MARKET HIGH ────────────────────────────────────────────────
var float premarket_high = 0.0
var label pmh_lbl        = na

if new_day
    premarket_high := 0.0

in_premarket = hour_est < 9 or (hour_est == 9 and minute_est < 30)
if in_premarket
    premarket_high := math.max(premarket_high, high)

prevday_high  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
effective_pmh = if premarket_high > 0
    premarket_high
else if not na(prevday_high) and prevday_high > 0
    prevday_high
else if not na(high[1])
    high[1]
else
    high

pmh_tag = premarket_high > 0 ? "PMH" : "PDH"

plot(effective_pmh > 0 ? effective_pmh : na, "PM High",
     color=color.orange, linewidth=1, style=plot.style_circles)

if barstate.islast and effective_pmh > 0
    if not na(pmh_lbl)
        label.delete(pmh_lbl)
    pmh_lbl := label.new(bar_index + 2, effective_pmh,
                 pmh_tag + "  " + str.tostring(effective_pmh, "#.##"),
                 style=label.style_label_left, color=color.orange,
                 textcolor=color.black, size=size.small)

// ── SECTION 5: VOLUME ─────────────────────────────────────────────────────────
avg_vol      = ta.sma(volume, 20)
rel_vol      = avg_vol > 0 ? volume / avg_vol : 0.0
recent_vol   = volume    + volume[1] + volume[2]
earlier_vol  = volume[4] + volume[5] + volume[6]
vol_building = recent_vol > earlier_vol
vol_trend    = vol_building ? "BUILDING" : "FADING"
vol_color    = vol_building ? color.green : color.red

// ── SECTION 6: GAP CALCULATION ────────────────────────────────────────────────
daily_avg5_close = request.security(syminfo.tickerid, "D", ta.sma(close, 5)[1],
                   lookahead=barmerge.lookahead_off)

var float gap_pct   = 0.0
var bool  first_bar = false

if new_day
    first_bar := true
    gap_pct   := 0.0

if first_bar
    prev_c        = not na(close[1]) and close[1] > 0.0 ? close[1] : na
    raw_gap       = not na(prev_c) ? (open - prev_c) / prev_c * 100 : 0.0
    fallback_base = not na(daily_avg5_close) and daily_avg5_close > 0.0 ? daily_avg5_close : na
    gap_pct := if raw_gap != 0.0
        raw_gap
    else if not na(fallback_base)
        (high - fallback_base) / fallback_base * 100
    else
        0.0
    first_bar := false

// ── SECTION 7: VWAP RECLAIM ENTRY LOGIC ──────────────────────────────────────
// Step 1: Track when price has touched or crossed below VWAP during the session.
//         This is the "pullback" — weak hands being shaken out.
// Step 2: Entry fires on the FIRST candle that closes back above VWAP after
//         that pullback. This is the "reclaim" — smart money stepping back in.
// Stop:   Low of the entry candle minus ATR buffer. Tight, defined risk.

var bool touched_vwap = false
if new_day
    touched_vwap := false

// Mark pullback once price dips to or below VWAP after market open
if time_est >= 930 and close <= vwap
    touched_vwap := true

// Reclaim = close crosses above VWAP after having touched it
vwap_reclaim = touched_vwap and close > vwap and close[1] <= vwap

// ── SECTION 8: ALL ENTRY CONDITIONS ──────────────────────────────────────────
start_time      = ew_sh * 100 + ew_sm
end_time        = ew_eh * 100 + ew_em
in_entry_window = time_est >= start_time and time_est < end_time

volume_surge = volume > avg_vol * eff_vol
above_ema9   = close > ema9
rsi_ok       = rsi14 > 35 and rsi14 < 75
gap_ok       = gap_pct >= eff_gap
no_position  = strategy.position_size == 0

// ── SECTION 9: ONE TRADE PER DAY ─────────────────────────────────────────────
var bool traded_today = false
if new_day
    traded_today := false

// ── SECTION 10: CONFIDENCE SCORE (1–6) ───────────────────────────────────────
c1 = close > vwap                ? 1 : 0   // above VWAP
c2 = close > ema9                ? 1 : 0   // above 9 EMA
c3 = volume > avg_vol * 3        ? 1 : 0   // 3× average volume
c4 = gap_pct > 15                ? 1 : 0   // strong gap
c5 = HOT or SCORCHING            ? 1 : 0   // hot market
c6 = rsi14 >= 45 and rsi14 <= 70 ? 1 : 0   // RSI in range
confidence = c1 + c2 + c3 + c4 + c5 + c6

// Primary entry: VWAP reclaim with all filters
entry_signal = in_entry_window and vwap_reclaim and volume_surge and above_ema9 and rsi_ok and gap_ok and temp_ok and no_position
can_entry    = entry_signal and not traded_today and confidence >= eff_conf

// Backtest pipeline test: EMA crossover (no time window, fires throughout day)
ema_cross     = ta.crossover(close, ema9)
simple_signal = backtest_mode and ema_cross and volume > avg_vol and rsi14 > 50 and close > vwap and no_position and not traded_today
can_simple    = simple_signal and not can_entry

// ── SECTION 11: ENTRY EXECUTION ───────────────────────────────────────────────
var int   entry_bar    = 0
var float entry_stop   = na
var float entry_target = na
var line  stop_line    = na
var line  target_line  = na

// VWAP Reclaim primary entry
if can_entry
    stop_px  = low - atr14 * atr_mult
    risk_pts = close - stop_px
    tgt      = close + risk_pts * rr_input
    entry_stop   := stop_px
    entry_target := tgt
    entry_bar    := bar_index
    traded_today := true
    strategy.entry("GapPullback", strategy.long, comment="VP")
    strategy.exit("GP Exit", "GapPullback", stop=entry_stop, limit=entry_target)
    if not na(stop_line)
        line.delete(stop_line)
    if not na(target_line)
        line.delete(target_line)
    stop_line   := line.new(bar_index, entry_stop,   bar_index + 60, entry_stop,   color=color.red,   width=2, style=line.style_dashed)
    target_line := line.new(bar_index, entry_target, bar_index + 60, entry_target, color=color.green, width=2, style=line.style_dashed)

// EMA test entry (backtest only)
if can_simple
    s_stop   = close - atr14 * atr_mult
    s_target = close + (close - s_stop) * rr_input
    entry_stop   := s_stop
    entry_target := s_target
    entry_bar    := bar_index
    traded_today := true
    strategy.entry("EMATest", strategy.long, comment="ET")
    strategy.exit("EMATest Exit", "EMATest", stop=s_stop, limit=s_target)

plotshape(can_entry,  style=shape.triangleup, location=location.belowbar, color=color.green, size=size.normal, title="VWAP Reclaim Entry")
plotshape(can_simple, style=shape.diamond,    location=location.belowbar, color=color.aqua,  size=size.small,  title="EMA Test Entry")

// ── SECTION 12: EXITS ─────────────────────────────────────────────────────────
// Time stop: close after 60 bars (60 min on 1m chart)
if strategy.position_size > 0 and bar_index - entry_bar > 60
    strategy.close("Time Stop")

// VWAP stop: close drops back below VWAP while in position
if strategy.position_size > 0 and close < vwap
    strategy.close("VWAP Stop")

// ── SECTION 13: ALERTS ────────────────────────────────────────────────────────
if can_entry
    alert('{"action":"buy","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"stop":' + str.tostring(entry_stop) + ',"target":' + str.tostring(entry_target) + ',"confidence":' + str.tostring(confidence) + ',"reason":"VWAP reclaim after pullback","change_pct":' + str.tostring(math.round(gap_pct, 2)) + ',"relative_volume":' + str.tostring(math.round(rel_vol, 2)) + '}', alert.freq_once_per_bar_close)

if can_simple
    alert('{"action":"buy","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"stop":' + str.tostring(entry_stop) + ',"target":' + str.tostring(entry_target) + ',"confidence":' + str.tostring(confidence) + ',"reason":"EMA test entry - backtest","change_pct":' + str.tostring(math.round(gap_pct, 2)) + ',"relative_volume":' + str.tostring(math.round(rel_vol, 2)) + '}', alert.freq_once_per_bar_close)

if strategy.position_size[1] > 0 and strategy.position_size == 0
    alert('{"action":"close","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"reason":"exit triggered"}', alert.freq_once_per_bar_close)

// ── SECTION 14: INFO TABLE ────────────────────────────────────────────────────
var table info_tbl = table.new(position.top_right, 2, 11,
     bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1)

if barstate.islast
    table.cell(info_tbl, 0, 0,  "Cameron Ross",  text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 1, 0,  backtest_mode ? "BACKTEST" : "$500 LIVE", text_color=backtest_mode ? color.yellow : color.lime, text_size=size.small, bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 0, 1,  "Temperature",   text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 1,  temp_label,      text_color=temp_color,  text_size=size.small)
    table.cell(info_tbl, 0, 2,  "Gap %",         text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 2,  str.tostring(math.round(gap_pct, 2)) + "%", text_color=gap_pct >= eff_gap ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 3,  pmh_tag,         text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 3,  str.tostring(effective_pmh, "#.##"), text_color=color.orange, text_size=size.small)
    table.cell(info_tbl, 0, 4,  "VWAP Reclaim",  text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 4,  touched_vwap ? "READY — watching for reclaim" : "Waiting for pullback", text_color=touched_vwap ? color.lime : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 5,  "VWAP",          text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 5,  str.tostring(vwap, "#.##"), text_color=color.blue, text_size=size.small)
    table.cell(info_tbl, 0, 6,  "Volume Trend",  text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 6,  vol_trend,       text_color=vol_color,   text_size=size.small)
    table.cell(info_tbl, 0, 7,  "Confidence",    text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 7,  str.tostring(confidence) + " / 6", text_color=confidence >= eff_conf ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 8,  "Rel Volume",    text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 8,  str.tostring(math.round(rel_vol, 2)) + "x", text_color=rel_vol >= eff_vol ? color.green : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 9,  "Entry Window",  text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 9,  in_entry_window ? "ACTIVE" : "CLOSED", text_color=in_entry_window ? color.lime : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 10, "Traded Today",  text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 10, traded_today ? "YES — done for the day" : "NO", text_color=traded_today ? color.red : color.green, text_size=size.small)

// ── DEBUG VALUES (Data Window only — not plotted on price chart) ──────────────
// Hover over any bar in TradingView to see these in the Data Window panel.
// They are hidden from the chart so they don't cover your candles.
plot(effective_pmh, "PMH Debug",    color=color.orange, display=display.data_window)
plot(gap_pct,       "Gap Debug",    color=color.yellow, display=display.data_window)
plot(rel_vol,       "RelVol Debug", color=color.blue,   display=display.data_window)
plot(confidence,    "Conf Debug",   color=color.white,  display=display.data_window)

// ── Hidden series for alert placeholders ──────────────────────────────────────
plot(entry_stop,   "stop_price",   display=display.none)
plot(entry_target, "target_price", display=display.none)
