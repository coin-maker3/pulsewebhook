//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// PulseWebhook — Momentum Breakout | All Sessions
// Trades pre-market, regular, and after-hours. No daily trade cap.
// Trailing stop lets winners run. Re-entry allowed after exit.
// $500 account. Webull (0% commission).
// ─────────────────────────────────────────────────────────────────────────────
// ENTRY (same logic all sessions):
//   Price breaks above highest high of last 10 bars (momentum continuation)
//   + Volume surge (2x average)
//   + RSI 30–80 (not exhausted, not dead)
//   + Gap day (stock is gapping)
//
// EXIT:
//   Hard stop: Low of entry bar minus ATR buffer (thesis broken)
//   Trailing stop: Activates after 1R profit, trails 1.5 ATR below highest high
//   Time stop: 120 bars (2 hours on 1m) — move on if nothing happened
//   VWAP stop: Close below VWAP in regular session = momentum lost
//
// HOW TO USE:
//   1. Extended hours ON in TradingView chart settings
//   2. 1-minute chart
//   3. Pre-screen: gap >10%, low float, pre-market volume
//   4. Green triangle = entry. Red line = stop. Trailing stop moves up.
//   5. Let the trailing stop do its job. Never move your stop DOWN.
// ─────────────────────────────────────────────────────────────────────────────
strategy("PulseWebhook — Momentum", overlay=true,
     initial_capital    = 500,
     default_qty_type   = strategy.percent_of_equity,
     default_qty_value  = 10,
     commission_type    = strategy.commission.percent,
     commission_value   = 0.0,
     slippage           = 3,
     calc_on_every_tick = true)

// ── INPUTS ───────────────────────────────────────────────────────────────────
backtest_mode = input.bool(true, "Backtest Mode",
     tooltip="ON: lower thresholds for historical testing. OFF: live thresholds.")

start_date = input.time(timestamp("2024-01-01 00:00"), "Backtest Start Date",
     tooltip="Set to the day the stock gapped. Ignores flat history before.", group="Backtest Range")
end_date   = input.time(timestamp("2099-12-31 00:00"), "Backtest End Date",
     tooltip="Leave default to run to present.", group="Backtest Range")

in_date_range = time >= start_date and time <= end_date

min_gap      = input.float(10.0, "Min Gap % (live)",        minval=0.0, step=1.0,  group="Filters")
min_rel_vol  = input.float(2.0,  "Min Rel Volume (live)",   minval=0.1, step=0.1,  group="Filters")
atr_mult     = input.float(0.5,  "ATR Stop Buffer",         minval=0.1, step=0.1,  group="Filters")
trail_atr    = input.float(1.5,  "Trailing Stop ATR Mult",  minval=0.5, step=0.1,  group="Filters",
     tooltip="Trailing stop distance below highest high since entry. Lower = tighter trail.")
breakout_len = input.int(10,     "Breakout Lookback Bars",   minval=3,   maxval=30, group="Filters")
time_stop    = input.int(120,    "Time Stop (bars)",         minval=20,  maxval=300, group="Filters",
     tooltip="Close position if no move after this many bars.")

// Session windows
pm_sh = input.int(6,  "Pre-Market Start Hour EST",  minval=0, maxval=23, group="Pre-Market")
pm_sm = input.int(0,  "Pre-Market Start Min",       minval=0, maxval=59, group="Pre-Market")
pm_eh = input.int(9,  "Pre-Market End Hour EST",    minval=0, maxval=23, group="Pre-Market")
pm_em = input.int(25, "Pre-Market End Min",          minval=0, maxval=59, group="Pre-Market")

rs_sh = input.int(9,  "Regular Start Hour EST",     minval=0, maxval=23, group="Regular Session")
rs_sm = input.int(30, "Regular Start Min",           minval=0, maxval=59, group="Regular Session")
rs_eh = input.int(11, "Regular End Hour EST",        minval=0, maxval=23, group="Regular Session")
rs_em = input.int(30, "Regular End Min",             minval=0, maxval=59, group="Regular Session",
     tooltip="Extended to 11:30 — momentum can run past 10:15.")

ah_sh = input.int(16, "After-Hours Start Hour EST",  minval=0, maxval=23, group="After-Hours")
ah_sm = input.int(0,  "After-Hours Start Min",       minval=0, maxval=59, group="After-Hours")
ah_eh = input.int(19, "After-Hours End Hour EST",    minval=0, maxval=23, group="After-Hours")
ah_em = input.int(30, "After-Hours End Min",          minval=0, maxval=59, group="After-Hours")

// Effective thresholds
eff_gap = backtest_mode ? 5.0 : min_gap
eff_vol = backtest_mode ? 1.5 : min_rel_vol

// ── TIME ─────────────────────────────────────────────────────────────────────
hour_est   = hour(time, "America/New_York")
minute_est = minute(time, "America/New_York")
time_est   = hour_est * 100 + minute_est
new_day    = not na(dayofweek[1]) and dayofweek != dayofweek[1]

pm_start = pm_sh * 100 + pm_sm
pm_end   = pm_eh * 100 + pm_em
rs_start = rs_sh * 100 + rs_sm
rs_end   = rs_eh * 100 + rs_em
ah_start = ah_sh * 100 + ah_sm
ah_end   = ah_eh * 100 + ah_em

in_premarket  = time_est >= pm_start and time_est < pm_end
in_regular    = time_est >= rs_start and time_est < rs_end
in_afterhours = time_est >= ah_start and time_est < ah_end
in_any_window = in_premarket or in_regular or in_afterhours

// ── INDICATORS ───────────────────────────────────────────────────────────────
atr14 = ta.atr(14)
vwap  = ta.vwap(hlc3)
ema9  = ta.ema(close, 9)
ema20 = ta.ema(close, 20)
rsi14 = ta.rsi(close, 14)

plot(vwap,  "VWAP",   color=color.blue,   linewidth=2)
plot(ema9,  "9 EMA",  color=color.orange,  linewidth=1)
plot(ema20, "20 EMA", color=color.yellow,  linewidth=1)

// ── MARKET TEMPERATURE ───────────────────────────────────────────────────────
bar_change_pct = na(close[1]) or close[1] == 0.0 ? 0.0 : (close - close[1]) / close[1] * 100

var float max_change_today = 0.0
if new_day
    max_change_today := 0.0
max_change_today := math.max(max_change_today, bar_change_pct)

SCORCHING = max_change_today > 50
HOT       = max_change_today > 30 and max_change_today <= 50
WARM      = max_change_today > 15 and max_change_today <= 30
COLD      = max_change_today > 5  and max_change_today <= 15
DEAD      = max_change_today <= 5

temp_ok    = backtest_mode ? not DEAD : (SCORCHING or HOT or WARM)
temp_label = SCORCHING ? "SCORCHING" : HOT ? "HOT" : WARM ? "WARM" : COLD ? "COLD" : "DEAD"
temp_color = if SCORCHING
    color.white
else if HOT
    color.green
else if WARM
    color.yellow
else if COLD
    color.blue
else
    color.gray

// ── PRE-MARKET HIGH ──────────────────────────────────────────────────────────
var float premarket_high = 0.0
var label pmh_lbl        = na

if new_day
    premarket_high := 0.0
if in_premarket
    premarket_high := math.max(premarket_high, high)

prevday_high  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
effective_pmh = if premarket_high > 0
    premarket_high
else if not na(prevday_high) and prevday_high > 0
    prevday_high
else if not na(high[1])
    high[1]
else
    high

pmh_tag = premarket_high > 0 ? "PMH" : "PDH"

plot(effective_pmh > 0 ? effective_pmh : na, "PM High",
     color=color.orange, linewidth=1, style=plot.style_circles)

if barstate.islast and effective_pmh > 0
    if not na(pmh_lbl)
        label.delete(pmh_lbl)
    pmh_lbl := label.new(bar_index + 2, effective_pmh,
                 pmh_tag + "  " + str.tostring(effective_pmh, "#.##"),
                 style=label.style_label_left, color=color.orange,
                 textcolor=color.black, size=size.small)

// ── VOLUME ───────────────────────────────────────────────────────────────────
avg_vol      = ta.sma(volume, 20)
avg_vol_10   = ta.sma(volume, 10)
rel_vol      = avg_vol > 0 ? volume / avg_vol : 0.0
recent_vol   = volume    + volume[1] + volume[2]
earlier_vol  = volume[4] + volume[5] + volume[6]
vol_building = recent_vol > earlier_vol
vol_trend    = vol_building ? "BUILDING" : "FADING"
vol_color    = vol_building ? color.green : color.red

// ── GAP CALCULATION ──────────────────────────────────────────────────────────
daily_avg5_close = request.security(syminfo.tickerid, "D", ta.sma(close, 5)[1],
                   lookahead=barmerge.lookahead_off)

var float gap_pct   = 0.0
var bool  first_bar = false

if new_day
    first_bar := true
    gap_pct   := 0.0

if first_bar
    prev_c        = not na(close[1]) and close[1] > 0.0 ? close[1] : na
    raw_gap       = not na(prev_c) ? (open - prev_c) / prev_c * 100 : 0.0
    fallback_base = not na(daily_avg5_close) and daily_avg5_close > 0.0 ? daily_avg5_close : na
    gap_pct := if raw_gap != 0.0
        raw_gap
    else if not na(fallback_base)
        (high - fallback_base) / fallback_base * 100
    else
        0.0
    first_bar := false

// ── ENTRY LOGIC — ONE SIGNAL, ALL SESSIONS ───────────────────────────────────
// Momentum breakout: price clears the highest high of last N bars + volume surge
// This catches the move when it's HAPPENING, not after a pullback.

highest_N     = ta.highest(high, breakout_len)
breakout      = close > highest_N[1] and close > open    // new high + bullish candle
vol_surge     = volume > avg_vol * eff_vol                // volume confirms it's real
rsi_ok        = rsi14 > 30 and rsi14 < 80                 // not dead, not blow-off top
gap_ok        = gap_pct >= eff_gap
above_ema     = close > ema9                              // trend intact
no_position   = strategy.position_size == 0

can_entry = in_date_range and in_any_window and breakout and vol_surge and rsi_ok and gap_ok and temp_ok and above_ema and no_position

// ── ENTRY EXECUTION ──────────────────────────────────────────────────────────
var int   entry_bar    = 0
var float entry_price  = na
var float entry_stop   = na
var float highest_since = na
var line  stop_line    = na

if can_entry
    stop_px     = low - atr14 * atr_mult
    entry_stop   := stop_px
    entry_price  := close
    entry_bar    := bar_index
    highest_since := high

    session_tag = if in_premarket
        "PM"
    else if in_regular
        "REG"
    else
        "AH"

    strategy.entry("Momentum", strategy.long, comment=session_tag)
    strategy.exit("Hard Stop", "Momentum", stop=entry_stop)

    if not na(stop_line)
        line.delete(stop_line)
    stop_line := line.new(bar_index, entry_stop, bar_index + 60, entry_stop,
                 color=color.red, width=2, style=line.style_dashed)

plotshape(can_entry, style=shape.triangleup, location=location.belowbar,
         color=color.green, size=size.normal, title="Momentum Entry")

// ── TRAILING STOP + EXITS ────────────────────────────────────────────────────
// Track highest high since entry. Once profit > 1R, start trailing.
// Trail = highest high since entry minus (ATR * trail multiplier)

if strategy.position_size > 0
    highest_since := math.max(nz(highest_since, high), high)

    risk_1r       = nz(entry_price, close) - nz(entry_stop, close - atr14)
    profit_now    = close - nz(entry_price, close)
    past_1r       = profit_now >= risk_1r and risk_1r > 0

    // Trailing stop: tighten once past 1R
    if past_1r
        trail_level = highest_since - atr14 * trail_atr
        // Only move stop UP, never down
        if trail_level > nz(entry_stop, 0)
            entry_stop := trail_level
            strategy.exit("Trail Stop", "Momentum", stop=entry_stop)
            // Update the stop line
            if not na(stop_line)
                line.delete(stop_line)
            stop_line := line.new(bar_index - 5, entry_stop, bar_index + 30, entry_stop,
                         color=color.fuchsia, width=2, style=line.style_dashed)

// Time stop — don't sit in dead trades
if strategy.position_size > 0 and bar_index - entry_bar > time_stop
    strategy.close("Time Stop")

// VWAP stop — only in regular session (extended hours VWAP is unreliable)
if strategy.position_size > 0 and in_regular and close < vwap and close < ema9
    strategy.close("VWAP Stop")

// Reset tracking vars on flat
if strategy.position_size == 0 and strategy.position_size[1] > 0
    highest_since := na
    entry_price   := na

// ── ALERTS ───────────────────────────────────────────────────────────────────
if can_entry
    session_name = if in_premarket
        "pre-market"
    else if in_regular
        "regular"
    else
        "after-hours"
    alert('{"action":"buy","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"stop":' + str.tostring(entry_stop) + ',"session":"' + session_name + '","gap_pct":' + str.tostring(math.round(gap_pct, 2)) + ',"rel_vol":' + str.tostring(math.round(rel_vol, 2)) + ',"rsi":' + str.tostring(math.round(rsi14, 1)) + '}', alert.freq_once_per_bar_close)

if strategy.position_size[1] > 0 and strategy.position_size == 0
    alert('{"action":"close","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar_close)

// ── INFO TABLE ───────────────────────────────────────────────────────────────
var table info_tbl = table.new(position.top_right, 2, 11,
     bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1)

current_session = if in_premarket
    "PRE-MARKET"
else if in_regular
    "REGULAR"
else if in_afterhours
    "AFTER-HOURS"
else
    "CLOSED"

session_color = if in_premarket
    color.yellow
else if in_regular
    color.lime
else if in_afterhours
    color.orange
else
    color.gray

in_trade_now = strategy.position_size > 0
trade_pnl    = in_trade_now ? (close - nz(entry_price, close)) / nz(entry_price, close) * 100 : 0.0

if barstate.islast
    table.cell(info_tbl, 0, 0,  "PulseWebhook",    text_color=color.white, text_size=size.small, bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 1, 0,  backtest_mode ? "BACKTEST" : "LIVE", text_color=backtest_mode ? color.yellow : color.lime, text_size=size.small, bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 0, 1,  "Session",          text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 1,  current_session,    text_color=session_color, text_size=size.small)
    table.cell(info_tbl, 0, 2,  "Temperature",      text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 2,  temp_label,         text_color=temp_color,    text_size=size.small)
    table.cell(info_tbl, 0, 3,  "Gap %",            text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 3,  str.tostring(math.round(gap_pct, 2)) + "%", text_color=gap_pct >= eff_gap ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 4,  pmh_tag,            text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 4,  str.tostring(effective_pmh, "#.##"), text_color=color.orange, text_size=size.small)
    table.cell(info_tbl, 0, 5,  "Volume",           text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 5,  str.tostring(math.round(rel_vol, 2)) + "x  " + vol_trend, text_color=vol_color, text_size=size.small)
    table.cell(info_tbl, 0, 6,  "RSI",              text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 6,  str.tostring(math.round(rsi14, 1)), text_color=rsi_ok ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 7,  "Entry Window",     text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 7,  in_any_window ? "OPEN" : "CLOSED", text_color=in_any_window ? color.lime : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 8,  "Position",         text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 8,  in_trade_now ? str.tostring(math.round(trade_pnl, 2)) + "%" : "FLAT", text_color=in_trade_now ? (trade_pnl >= 0 ? color.lime : color.red) : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 9,  "Stop",             text_color=color.white,   text_size=size.small)
    table.cell(info_tbl, 1, 9,  in_trade_now ? str.tostring(entry_stop, "#.##") : "—", text_color=color.red, text_size=size.small)
    table.cell(info_tbl, 0, 10, "Trail Active",     text_color=color.white,   text_size=size.small)
    trailed = in_trade_now and not na(entry_price) and not na(entry_stop) and (close - entry_price) >= (entry_price - entry_stop)
    table.cell(info_tbl, 1, 10, in_trade_now ? (trailed ? "YES" : "NO") : "—", text_color=trailed ? color.lime : color.gray, text_size=size.small)

// ── DEBUG (Data Window only) ─────────────────────────────────────────────────
plot(effective_pmh,    "PMH Debug",     color=color.orange, display=display.data_window)
plot(gap_pct,          "Gap Debug",     color=color.yellow, display=display.data_window)
plot(rel_vol,          "RelVol Debug",  color=color.blue,   display=display.data_window)
plot(nz(entry_stop),   "Stop Debug",   color=color.red,    display=display.data_window)
plot(nz(highest_since),"Trail Hi Debug",color=color.lime,   display=display.data_window)

// ── Hidden series for alert placeholders ─────────────────────────────────────
plot(entry_stop, "stop_price", display=display.none)
