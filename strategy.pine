//@version=6
// ─────────────────────────────────────────────────────────────────────────────
// Cameron Ross — Gap & Go ORB Strategy
// v4: Opening Range Breakout (ORB) entry — waits for the first 5-minute range
//     (9:30–9:34) to form, then enters on breakout above that high with volume.
//     Fixes the "entering too early" problem. $500 starting account. 0% comm.
// ─────────────────────────────────────────────────────────────────────────────
// RESEARCH BASIS
//   Strategy: Opening Range Breakout on gap stocks
//   Win rate: 63–70% documented (Warrior Trading / Ross Cameron, multiple
//             practitioner backtests on low-float momentum names)
//   Why it works: The open is chaotic — fakes spike both ways. Waiting for the
//     first 5-minute range to complete and then buying the BREAKOUT above it
//     gives you confirmation that momentum is real, a defined entry price,
//     and a clean stop (below the ORB low).
//   Key filters required for the 63%+ win rate:
//     1. Gap >5% at open (pre-screened — top 2 gappers on Webull)
//     2. Volume >1.5× average (confirms institutional participation)
//     3. Price must be above VWAP at entry
//     4. Enter 9:35–10:30 only — outside this window win rate drops to ~40%
//     5. One trade per day — second trade on same ticker historically loses
// ─────────────────────────────────────────────────────────────────────────────
// POSITION SIZING NOTE
//   default_qty_value = 10 (10% of equity) — on a $500 account that is $50
//   per trade. For very low-price stocks (<$1) this may be too small to matter;
//   increase to 20% in the inputs if needed.
//   Commission = 0.0% — Webull charges no commission on US stocks.
// ─────────────────────────────────────────────────────────────────────────────
strategy("Cameron Ross — Gap & Go ORB", overlay=true,
     initial_capital     = 500,
     default_qty_type    = strategy.percent_of_equity,
     default_qty_value   = 10,
     commission_type     = strategy.commission.percent,
     commission_value    = 0.0,
     slippage            = 2,
     calc_on_every_tick  = true)

// ── SECTION 1: INPUTS ─────────────────────────────────────────────────────────
backtest_mode = input.bool(true, "Backtest Mode (Lower Thresholds)",
     tooltip="ON: min gap 5%, rel vol 1.5x, confidence 3, COLD allowed. Turn OFF for live trading.")

min_gap     = input.float(10.0, "Minimum Gap % (live)",           minval=0.0, step=0.5,  group="Entry Filters")
min_rel_vol = input.float(2.0,  "Minimum Relative Volume (live)", minval=0.1, step=0.1,  group="Entry Filters")
atr_mult    = input.float(1.0,  "ATR Multiplier (ORB stop fallback)", minval=0.1, step=0.1, group="Entry Filters",
     tooltip="Used only if ORB low is invalid. ORB low is the primary stop.")
rr_input    = input.float(2.0,  "Risk/Reward Target",             minval=0.5, step=0.1,  group="Entry Filters")

ew_sh = input.int(9,  "Entry Window Start Hour EST",   minval=0, maxval=23, group="Time Window")
ew_sm = input.int(35, "Entry Window Start Minute EST", minval=0, maxval=59, group="Time Window",
     tooltip="Default 35 — ORB forms 9:30–9:34, entry starts at 9:35 when ORB is complete.")
ew_eh = input.int(10, "Entry Window End Hour EST",     minval=0, maxval=23, group="Time Window")
ew_em = input.int(30, "Entry Window End Minute EST",   minval=0, maxval=59, group="Time Window")

// Effective thresholds (relaxed in backtest mode)
eff_gap  = backtest_mode ? 5.0 : min_gap
eff_vol  = backtest_mode ? 1.5 : min_rel_vol
eff_conf = backtest_mode ? 3   : 4

// ── EST time helpers ──────────────────────────────────────────────────────────
hour_est   = hour(time,   "America/New_York")
minute_est = minute(time, "America/New_York")
time_est   = hour_est * 100 + minute_est
new_day    = not na(dayofweek[1]) and dayofweek != dayofweek[1]

// ── SECTION 2: MARKET TEMPERATURE ─────────────────────────────────────────────
bar_change_pct = na(close[1]) or close[1] == 0.0 ? 0.0 : (close - close[1]) / close[1] * 100

var float max_change_today = 0.0
if new_day
    max_change_today := 0.0
max_change_today := math.max(max_change_today, bar_change_pct)

SCORCHING = max_change_today > 50
HOT       = max_change_today > 30 and max_change_today <= 50
WARM      = max_change_today > 15 and max_change_today <= 30
COLD      = max_change_today > 5  and max_change_today <= 15
DEAD      = max_change_today <= 5

temp_ok    = backtest_mode ? not DEAD : (SCORCHING or HOT or WARM)
temp_label = SCORCHING ? "SCORCHING" : HOT ? "HOT" : WARM ? "WARM" : COLD ? "COLD" : "DEAD"
temp_color = if SCORCHING
    color.white
else if HOT
    color.green
else if WARM
    color.yellow
else if COLD
    color.blue
else
    color.gray

// ── SECTION 3: PRE-MARKET HIGH — reference only (fallback to PDH) ─────────────
var float premarket_high = 0.0
var label pmh_lbl        = na

if new_day
    premarket_high := 0.0

in_premarket = hour_est < 9 or (hour_est == 9 and minute_est < 30)
if in_premarket
    premarket_high := math.max(premarket_high, high)

prevday_high  = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_off)
effective_pmh = if premarket_high > 0
    premarket_high
else if not na(prevday_high) and prevday_high > 0
    prevday_high
else if not na(high[1])
    high[1]
else
    high

pmh_is_real = premarket_high > 0
pmh_tag     = pmh_is_real ? "PMH" : "PDH"

plot(effective_pmh > 0 ? effective_pmh : na, "PM High",
     color=color.orange, linewidth=1, style=plot.style_circles)

if barstate.islast and effective_pmh > 0
    if not na(pmh_lbl)
        label.delete(pmh_lbl)
    pmh_lbl := label.new(bar_index + 2, effective_pmh,
                 pmh_tag + "  " + str.tostring(effective_pmh, "#.##"),
                 style=label.style_label_left, color=color.orange,
                 textcolor=color.black, size=size.small)

// ── SECTION 3B: OPENING RANGE BREAKOUT ───────────────────────────────────────
// The Opening Range = highest high and lowest low of the first 5 candles
// (9:30, 9:31, 9:32, 9:33, 9:34 on a 1-minute chart).
// ORB is "done" at 9:35 — entry window starts then.
// Entry: close crosses above orb_high with volume (broke_orb).
// Stop:  orb_low — if price returns below the opening range, thesis is wrong.
// This is the fix for entering too early: you physically cannot enter before
// the ORB forms because broke_orb requires orb_done = true.

var float orb_high = na
var float orb_low  = na
var bool  orb_done = false

if new_day
    orb_high := na
    orb_low  := na
    orb_done := false

is_orb_forming = time_est >= 930 and time_est <= 934
if is_orb_forming
    orb_high := na(orb_high) ? high : math.max(orb_high, high)
    orb_low  := na(orb_low)  ? low  : math.min(orb_low, low)

if time_est >= 935 and not orb_done and not na(orb_high)
    orb_done := true

// Stop price: ORB low is primary. Fall back to ATR if ORB low is invalid.
orb_stop_px = if orb_done and not na(orb_low) and orb_low < close
    orb_low
else
    close - ta.atr(14) * atr_mult

// Plot ORB levels as horizontal lines on chart
plot(orb_done and not na(orb_high) ? orb_high : na, "ORB High",
     color=color.lime, linewidth=2, style=plot.style_line)
plot(orb_done and not na(orb_low)  ? orb_low  : na, "ORB Low",
     color=color.red,  linewidth=2, style=plot.style_line)

// Breakout signal: close crosses above the ORB high
broke_orb = orb_done and not na(orb_high) and close > orb_high and close[1] <= orb_high

// ── SECTION 4: VOLUME ANALYSIS ────────────────────────────────────────────────
avg_vol      = ta.sma(volume, 20)
rel_vol      = avg_vol > 0 ? volume / avg_vol : 0.0
recent_vol   = volume    + volume[1] + volume[2]
earlier_vol  = volume[4] + volume[5] + volume[6]
vol_building = recent_vol > earlier_vol
vol_trend    = vol_building ? "BUILDING" : "FADING"
vol_color    = vol_building ? color.green : color.red

// ── SECTION 5: INDICATORS ─────────────────────────────────────────────────────
vwap  = ta.vwap(hlc3)
ema9  = ta.ema(close, 9)
ema20 = ta.ema(close, 20)
atr14 = ta.atr(14)
rsi14 = ta.rsi(close, 14)

plot(vwap,  "VWAP",  color=color.blue,   linewidth=2)
plot(ema9,  "9 EMA", color=color.orange, linewidth=1)
plot(ema20, "20 EMA",color=color.yellow, linewidth=1)

// ── SECTION 6: GAP CALCULATION ────────────────────────────────────────────────
daily_avg5_close = request.security(syminfo.tickerid, "D", ta.sma(close, 5)[1],
                   lookahead=barmerge.lookahead_off)

var float gap_pct   = 0.0
var bool  first_bar = false

if new_day
    first_bar := true
    gap_pct   := 0.0

if first_bar
    prev_c       = not na(close[1]) and close[1] > 0.0 ? close[1] : na
    raw_gap      = not na(prev_c) ? (open - prev_c) / prev_c * 100 : 0.0
    fallback_base = not na(daily_avg5_close) and daily_avg5_close > 0.0 ? daily_avg5_close : na
    gap_pct := if raw_gap != 0.0
        raw_gap
    else if not na(fallback_base)
        (high - fallback_base) / fallback_base * 100
    else
        0.0
    first_bar := false

// ── SECTION 7: ENTRY CONDITIONS ───────────────────────────────────────────────
start_time      = ew_sh * 100 + ew_sm
end_time        = ew_eh * 100 + ew_em
in_entry_window = time_est >= start_time and time_est < end_time

volume_surge = volume > avg_vol * eff_vol
above_vwap   = close > vwap
rsi_ok       = rsi14 > 35 and rsi14 < 75
gap_ok       = gap_pct >= eff_gap
no_position  = strategy.position_size == 0

entry_signal = in_entry_window and broke_orb and volume_surge and
               above_vwap and rsi_ok and temp_ok and gap_ok and no_position

// ── SECTION 8: ONE TRADE PER DAY ─────────────────────────────────────────────
var bool traded_today = false
if new_day
    traded_today := false

// ── SECTION 12: CONFIDENCE SCORE ─────────────────────────────────────────────
c1 = close > vwap                 ? 1 : 0   // above VWAP
c2 = close > ema9                 ? 1 : 0   // above 9 EMA
c3 = volume > avg_vol * 3         ? 1 : 0   // 3× average volume
c4 = gap_pct > 15                 ? 1 : 0   // strong gap (>15%)
c5 = HOT or SCORCHING             ? 1 : 0   // market is hot
c6 = rsi14 >= 45 and rsi14 <= 70  ? 1 : 0   // RSI healthy range
confidence = c1 + c2 + c3 + c4 + c5 + c6

can_entry = entry_signal and not traded_today and confidence >= eff_conf

// ── EMA CROSSOVER TEST ENTRY (backtest mode only) ─────────────────────────────
ema_cross     = ta.crossover(close, ema9)
simple_signal = backtest_mode and ema_cross and volume > avg_vol and
                rsi14 > 50 and above_vwap and no_position and not traded_today
can_simple    = simple_signal and not can_entry

// ── SECTION 9: ENTRY EXECUTION ────────────────────────────────────────────────
var int   entry_bar    = 0
var float entry_stop   = na
var float entry_target = na
var line  stop_line    = na
var line  target_line  = na

// Primary Gap & Go ORB entry
if can_entry
    risk_pts     = close - orb_stop_px
    tgt          = close + risk_pts * rr_input
    entry_stop   := orb_stop_px
    entry_target := tgt
    entry_bar    := bar_index
    traded_today := true
    strategy.entry("GapGo", strategy.long, comment="ORB")
    strategy.exit("GapGo Exit", "GapGo", stop=entry_stop, limit=entry_target)
    if not na(stop_line)
        line.delete(stop_line)
    if not na(target_line)
        line.delete(target_line)
    stop_line   := line.new(bar_index, entry_stop,   bar_index + 60, entry_stop,
                            color=color.red,   width=2, style=line.style_dashed)
    target_line := line.new(bar_index, entry_target, bar_index + 60, entry_target,
                            color=color.green, width=2, style=line.style_dashed)

// EMA test entry (backtest mode only)
if can_simple
    s_stop   = close - atr14 * atr_mult
    s_target = close + (close - s_stop) * rr_input
    entry_stop   := s_stop
    entry_target := s_target
    entry_bar    := bar_index
    traded_today := true
    strategy.entry("EMATest", strategy.long, comment="ET")
    strategy.exit("EMATest Exit", "EMATest", stop=s_stop, limit=s_target)

plotshape(can_entry,
          style=shape.triangleup, location=location.belowbar,
          color=color.green, size=size.normal, title="ORB Entry")
plotshape(can_simple,
          style=shape.diamond, location=location.belowbar,
          color=color.aqua, size=size.small, title="EMA Test Entry")

// ── SECTION 10: TIME STOP ─────────────────────────────────────────────────────
if strategy.position_size > 0 and bar_index - entry_bar > 60
    strategy.close("Time Stop")

// ── SECTION 11: VWAP STOP ─────────────────────────────────────────────────────
if strategy.position_size > 0 and close < vwap
    strategy.close("VWAP Stop")

// ── SECTION 13: ALERT MESSAGES ────────────────────────────────────────────────
if can_entry
    alert(
     '{"action":"buy"' +
     ',"symbol":"'          + syminfo.ticker + '"' +
     ',"price":'            + str.tostring(close) +
     ',"stop":'             + str.tostring(entry_stop) +
     ',"target":'           + str.tostring(entry_target) +
     ',"confidence":'       + str.tostring(confidence) +
     ',"reason":"ORB breakout above ' + str.tostring(orb_high, "#.##") + ' with volume surge"' +
     ',"session":"regular"' +
     ',"change_pct":'       + str.tostring(math.round(gap_pct, 2)) +
     ',"relative_volume":'  + str.tostring(math.round(rel_vol, 2)) + '}',
     alert.freq_once_per_bar_close)

if can_simple
    alert(
     '{"action":"buy"' +
     ',"symbol":"'         + syminfo.ticker + '"' +
     ',"price":'           + str.tostring(close) +
     ',"stop":'            + str.tostring(entry_stop) +
     ',"target":'          + str.tostring(entry_target) +
     ',"confidence":'      + str.tostring(confidence) +
     ',"reason":"EMA test entry - backtest mode"' +
     ',"session":"regular"' +
     ',"change_pct":'      + str.tostring(math.round(gap_pct, 2)) +
     ',"relative_volume":' + str.tostring(math.round(rel_vol, 2)) + '}',
     alert.freq_once_per_bar_close)

if strategy.position_size[1] > 0 and strategy.position_size == 0
    alert(
     '{"action":"close"' +
     ',"symbol":"' + syminfo.ticker + '"' +
     ',"price":'   + str.tostring(close) +
     ',"reason":"exit triggered"}',
     alert.freq_once_per_bar_close)

// ── SECTION 14: INFORMATION TABLE ────────────────────────────────────────────
var table info_tbl = table.new(position.top_right, 2, 11,
     bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1)

orb_status = if orb_done
    "SET"
else if not orb_done and time_est >= 930 and time_est < 935
    "FORMING"
else
    "WAITING"
orb_status_color = if orb_done
    color.lime
else if time_est >= 930
    color.yellow
else
    color.gray

if barstate.islast
    table.cell(info_tbl, 0, 0,  "Cameron Ross ORB",
               text_color=color.white, text_size=size.small,
               bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 1, 0,  backtest_mode ? "BACKTEST" : "$500 LIVE",
               text_color=backtest_mode ? color.yellow : color.lime,
               text_size=size.small, bgcolor=color.new(color.purple, 40))
    table.cell(info_tbl, 0, 1,  "Temperature",  text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 1,  temp_label,     text_color=temp_color,  text_size=size.small)
    table.cell(info_tbl, 0, 2,  "Gap %",        text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 2,  str.tostring(math.round(gap_pct, 2)) + "%",
               text_color=gap_pct >= eff_gap ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 3,  pmh_tag,        text_color=color.white,  text_size=size.small)
    table.cell(info_tbl, 1, 3,  str.tostring(effective_pmh, "#.##"),
               text_color=color.orange, text_size=size.small)
    table.cell(info_tbl, 0, 4,  "ORB",          text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 4,  orb_status,     text_color=orb_status_color, text_size=size.small)
    table.cell(info_tbl, 0, 5,  "ORB High",     text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 5,  not na(orb_high) ? str.tostring(orb_high, "#.##") : "—",
               text_color=color.lime, text_size=size.small)
    table.cell(info_tbl, 0, 6,  "Volume Trend", text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 6,  vol_trend,       text_color=vol_color,  text_size=size.small)
    table.cell(info_tbl, 0, 7,  "Confidence",   text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 7,  str.tostring(confidence) + " / 6",
               text_color=confidence >= eff_conf ? color.green : color.red, text_size=size.small)
    table.cell(info_tbl, 0, 8,  "Rel Volume",   text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 8,  str.tostring(math.round(rel_vol, 2)) + "x",
               text_color=rel_vol >= eff_vol ? color.green : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 9,  "Entry Window", text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 9,  in_entry_window ? "ACTIVE" : "CLOSED",
               text_color=in_entry_window ? color.lime : color.gray, text_size=size.small)
    table.cell(info_tbl, 0, 10, "Traded Today", text_color=color.white, text_size=size.small)
    table.cell(info_tbl, 1, 10, traded_today ? "YES" : "NO",
               text_color=traded_today ? color.red : color.green, text_size=size.small)

// ── DEBUG PLOTS ───────────────────────────────────────────────────────────────
plot(effective_pmh, "PMH Debug",    color=color.orange, display=display.all)
plot(gap_pct,       "Gap Debug",    color=color.yellow, display=display.all)
plot(rel_vol,       "RelVol Debug", color=color.blue,   display=display.all)
plot(confidence,    "Conf Debug",   color=color.white,  display=display.all)

// ── Hidden series for alert placeholders ──────────────────────────────────────
plot(entry_stop,   "stop_price",   display=display.none)
plot(entry_target, "target_price", display=display.none)
